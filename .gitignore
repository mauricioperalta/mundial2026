# Go
/wm-pickems
/tmp/

# PocketBase runtime data (DB, storage, logs)
/pb_data/

# Node / SvelteKit
frontend/node_modules/
frontend/.svelte-kit/
frontend/build/

# Embedded build output — generated by the frontend build, not committed.
# Only an empty .gitkeep is tracked so `//go:embed all:build` compiles
# without a frontend build (and so a build never dirties git status).
/internal/web/build/*
!/internal/web/build/.gitkeep

# Env
.env
*.local

# Editor / OS
.DS_Store
.directory
backup_*/
